{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(swift build:*)",
      "Bash(swift test:*)",
      "Bash(swift package describe:*)",
      "Bash(swift package resolve:*)",
      "Bash(swift package show-dependencies:*)",
      "Bash(swift --version)",
      "Bash(make test)",
      "Bash(make:*)",
      "Bash(xcrun llvm-cov:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git fetch:*)",
      "Bash(git remote -v)",
      "Bash(git rev-parse:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(ls:*)",
      "Bash(find . -name *)",
      "Bash(find Sources -name *)",
      "Bash(find Tests -name *)"
    ]
  }
}
